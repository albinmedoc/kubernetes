apiVersion: v1
kind: Secret
metadata:
  name: grafana-secrets
  namespace: monitoring
type: Opaque
stringData:
  GF_SECURITY_ADMIN_USER: admin
  GF_SECURITY_ADMIN_PASSWORD: replace-with-grafana-admin-password
  GF_AUTH_GENERIC_OAUTH_CLIENT_ID: replace-with-authentik-client-id
  GF_AUTH_GENERIC_OAUTH_CLIENT_SECRET: replace-with-authentik-client-secret
