apiVersion: v1
kind: Secret
metadata:
  name: velero-cloud-credentials
  namespace: velero
type: Opaque
stringData:
  cloud: |
    [default]
    aws_access_key_id=<B2_KEY_ID>
    aws_secret_access_key=<B2_APPLICATION_KEY>
---
apiVersion: v1
kind: Secret
metadata:
  name: velero-repo-credentials
  namespace: velero
type: Opaque
stringData:
  repository-password: <KOPIA_REPOSITORY_PASSWORD>
